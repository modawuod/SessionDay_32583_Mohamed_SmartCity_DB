-- PHASE 1: DDL (Tables & Constraints)
DROP TABLE City_Audit_Log CASCADE CONSTRAINTS;
DROP TABLE Services CASCADE CONSTRAINTS;
DROP TABLE Buildings CASCADE CONSTRAINTS;
DROP TABLE Citizens CASCADE CONSTRAINTS;
DROP TABLE Districts CASCADE CONSTRAINTS;
DROP SEQUENCE audit_seq;

CREATE TABLE Districts (
    district_id INT PRIMARY KEY,
    district_name VARCHAR2(100) NOT NULL UNIQUE
);

CREATE TABLE Citizens (
    citizen_id INT PRIMARY KEY,
    full_name VARCHAR2(150) NOT NULL,
    age INT CHECK (age >= 0),
    gender VARCHAR2(10) CHECK (gender IN ('Male', 'Female')),
    district_id INT,
    CONSTRAINT fk_citizen_district FOREIGN KEY (district_id) REFERENCES Districts(district_id) ON DELETE SET NULL
);

CREATE TABLE Buildings (
    building_id INT PRIMARY KEY,
    building_name VARCHAR2(150) NOT NULL,
    type VARCHAR2(50),
    district_id INT,
    CONSTRAINT fk_building_district FOREIGN KEY (district_id) REFERENCES Districts(district_id) ON DELETE CASCADE
);

CREATE TABLE Services (
    service_id INT PRIMARY KEY,
    service_name VARCHAR2(150) NOT NULL,
    building_id INT,
    CONSTRAINT fk_service_building FOREIGN KEY (building_id) REFERENCES Buildings(building_id) ON DELETE CASCADE
);

CREATE TABLE City_Audit_Log (
    log_id INT PRIMARY KEY,
    action_performed VARCHAR2(100),
    performed_by VARCHAR2(100),
    action_date TIMESTAMP
);

CREATE SEQUENCE audit_seq START WITH 1 INCREMENT BY 1;

