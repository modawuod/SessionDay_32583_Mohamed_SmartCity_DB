-- PHASE 3: Trigger & Auditing
CREATE OR REPLACE TRIGGER trg_audit_citizen_reg
AFTER INSERT ON Citizens FOR EACH ROW
BEGIN
    INSERT INTO City_Audit_Log VALUES (audit_seq.NEXTVAL, 'New Citizen: ' || :NEW.full_name, USER, SYSTIMESTAMP);
END;
/

-- PHASE 4: Packages & Procedures
CREATE OR REPLACE PACKAGE Smart_City_Pkg AS
    PROCEDURE register_citizen (p_id INT, p_name VARCHAR2, p_age INT, p_gender VARCHAR2, p_dist_id INT);
    FUNCTION get_district_population(p_dist_id INT) RETURN INT;
END Smart_City_Pkg;
/

CREATE OR REPLACE PACKAGE BODY Smart_City_Pkg AS
    PROCEDURE register_citizen (p_id INT, p_name VARCHAR2, p_age INT, p_gender VARCHAR2, p_dist_id INT) IS
    BEGIN
        INSERT INTO Citizens VALUES (p_id, p_name, p_age, p_gender, p_dist_id);
        DBMS_OUTPUT.PUT_LINE('Success!');
    EXCEPTION
        WHEN OTHERS THEN DBMS_OUTPUT.PUT_LINE('Error: ' || SQLERRM);
    END;

    FUNCTION get_district_population(p_dist_id INT) RETURN INT IS
        v_count INT;
    BEGIN
        SELECT COUNT(*) INTO v_count FROM Citizens WHERE district_id = p_dist_id;
        RETURN v_count;
    END;
END Smart_City_Pkg;
/
